#include <stdio.h>

int main()
{
    int arr[] = {10, 20, 30, 40, 50};
    int n = 5;
    int key = 30;
    int i, found = 0;

    for(i = 0; i < n; i++)
    {
        if(arr[i] == key)
        {
            printf("%d found at position %d\n", key, i + 1);
            found = 1;
            break;
        }
    }

    if(found == 0)
    {
        printf("%d not found in the array\n", key);
    }

    return 0;
}
