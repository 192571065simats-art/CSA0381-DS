#include <stdio.h>

int parent[10];

int find(int i)
{
    while(parent[i])
        i = parent[i];
    return i;
}

int uni(int i, int j)
{
    if(i != j)
    {
        parent[j] = i;
        return 1;
    }
    return 0;
}

int main()
{
    int cost[4][4] = {
        {999, 1, 3, 4},
        {1, 999, 2, 5},
        {3, 2, 999, 6},
        {4, 5, 6, 999}
    };

    int mincost = 0, ne = 1, a, b, u, v, min;

    while(ne < 4)
    {
        min = 999;

        for(int i = 0; i < 4; i++)
        {
            for(int j = 0; j < 4; j++)
            {
                if(cost[i][j] < min)
                {
                    min = cost[i][j];
                    a = u = i;
                    b = v = j;
                }
            }
        }

        u = find(u);
        v = find(v);

        if(uni(u, v))
        {
            printf("%d Edge (%d,%d) = %d\n", ne++, a, b, min);
            mincost += min;
        }

        cost[a][b] = cost[b][a] = 999;
    }

    printf("Minimum Cost = %d", mincost);

    return 0;
}
