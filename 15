#include <stdio.h>

#define SIZE 10

int hashTable[SIZE];

void insert(int key)
{
    int index = key % SIZE;

    while (hashTable[index] != -1)
    {
        index = (index + 1) % SIZE;
    }

    hashTable[index] = key;
}

void display()
{
    int i;
    printf("\nHash Table:\n");

    for (i = 0; i < SIZE; i++)
    {
        if (hashTable[i] != -1)
            printf("%d --> %d\n", i, hashTable[i]);
        else
            printf("%d --> Empty\n", i);
    }
}

int main()
{
    int i;
    int keys[] = {23, 43, 13, 27};

    for (i = 0; i < SIZE; i++)
        hashTable[i] = -1;

    for (i = 0; i < 4; i++)
        insert(keys[i]);

    display();

    return 0;
}
